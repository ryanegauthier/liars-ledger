{
  "name": "liars-ledger-api",
  "version": "1.0.0",
  "description": "Backend proxy for Liar's Ledger - holds API keys, proxies Claude/Mistral/VoteSmart",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cost": "vitest run --config vitest.cost.config.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "dependencies": {
    "@upstash/redis": "^1.38.0",
