# Liar's Ledger API — environment variables
# Copy to .env for local dev. Set these in Render environment variables for production.
# NEVER commit .env to git.

# ── Anthropic Claude ─────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=...

# ── Congress.gov ──────────────────────────────────────────────────────────────
CONGRESS_API_KEY=...

# ── VoteSmart v2 ──────────────────────────────────────────────────────────────
VOTESMART_EMAIL=ryan@liarsledger.com
VOTESMART_PASSWORD=...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS — comma-separated list of allowed origins ────────────────────────────
# For dev: chrome-extension://YOUR_EXTENSION_ID
# For prod: add your extension ID from chrome://extensions
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here
