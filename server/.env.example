# Liar's Ledger API - environment variables
# Copy to .env for local dev. Set these in Render environment variables for production.
# NEVER commit .env to git.

# ── Anthropic Claude ─────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-...

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=...

# ── Congress.gov ──────────────────────────────────────────────────────────────
CONGRESS_API_KEY=...

# ── VoteSmart v2 ──────────────────────────────────────────────────────────────
VOTESMART_EMAIL=ryan@liarsledger.com
VOTESMART_PASSWORD=...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS - comma-separated list of allowed origins ────────────────────────────
# For dev: chrome-extension://YOUR_EXTENSION_ID
# For prod: include the extension ID AND liarsledger.com (for /checkout/create)
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here,https://liarsledger.com

# ── Backend public URL (used to construct the Square webhook notification URL) ─
BACKEND_URL=https://api.liarsledger.com

# ── Square ────────────────────────────────────────────────────────────────────
# Access token: Square Developer Console → your app → Credentials
# Use sandbox token for dev, production token for prod.
SQUARE_ACCESS_TOKEN=EAAAl...

# "sandbox" or "production"
SQUARE_ENVIRONMENT=sandbox

# Square Developer Console → your app → Locations → copy any location ID
SQUARE_LOCATION_ID=...

# IDs from running: node server/scripts/setup-square-catalog.mjs
SQUARE_PLAN_ID=...
SQUARE_PLAN_VARIATION_ID=...

# Square Developer Console → your app → Webhooks → your endpoint → Signature Key
SQUARE_WEBHOOK_SIGNATURE_KEY=...
# Must exactly match the URL registered in Square Dashboard (scheme + path, no trailing slash)
SQUARE_WEBHOOK_NOTIFICATION_URL=https://api.liarsledger.com/webhook/square
# The pricing website origin (used for the success redirect URL and CORS)
PRICING_SITE_URL=https://liarsledger.com
